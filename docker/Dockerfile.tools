# Test runner: Python + MAVSDK para conectar no PX4 SITL via MAVLink.
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt requirements-dev.txt ./
RUN pip install --no-cache-dir -r requirements-dev.txt

COPY libs/ libs/
# tools/ entra no PR #2 (run_mission.py, extract_metrics.py, etc.)
COPY tests/ tests/
COPY pyproject.toml ./

ENV PYTHONPATH=/app

# Default: rodar testes SITL com marker 'sitl'.
CMD ["pytest", "tests/sitl", "-v", "-m", "sitl"]
